NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# URL publique de la plateforme
SITE_URL=https://votre-domaine.com

# Origines autorisées pour les appels API cross-origin, séparées par des virgules
ALLOWED_ORIGINS=https://votre-domaine.com,https://www.votre-domaine.com

# Comptes administrateurs autorisés à accéder aux routes protégées
ADMIN_EMAILS=admin@votre-domaine.com
ADMIN_PHONE_NUMBER=237600000000

# Secret pour les routes cron protégées
CRON_SECRET=remplacez-par-un-secret-long-et-aleatoire

# Supabase
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=anon-key

# WhatsApp Cloud API
META_ACCESS_TOKEN=votre-token-meta
WHATSAPP_PHONE_NUMBER_ID=votre-phone-number-id
