    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-helmet-async": "^3.0.0",
